{
  "manifest_version": 3,
  "name": "MCP2API Bridge",
  "version": "1.2",
  "description": "Connect ChatGPT/Gemini to local MCP Gateway",
  "permissions": ["scripting", "activeTab", "storage"],
  "host_permissions": [
    "http://localhost/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
