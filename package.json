{
  "name": "webmcp-monorepo",
  "version": "0.6.0",
  "private": true,
  "scripts": {
    "dev:vscode": "pnpm --filter mcp-gateway-vscode watch",
    "dev:browser": "pnpm --filter mcp-bridge-browser dev",
    "dev:desktop": "pnpm --filter mcp-gateway-desktop dev",
    "docs:dev": "dumi dev",
    "docs:build": "dumi build",
    "docs:preview": "dumi preview",
    "build": "pnpm run lint && pnpm -r run build",
    "lint": "eslint \"packages/**/src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"packages/**/src/**/*.{ts,tsx}\" --fix",
    "clean": "find . -name \"node_modules\" -type d -prune -exec rm -rf '{}' + && find . -name \"dist\" -type d -prune -exec rm -rf '{}' + && find . -name \"dist-electron\" -type d -prune -exec rm -rf '{}' + && rm -rf release docs-dist",
    "format": "prettier --write \"packages/**/*.{ts,tsx,md,json}\"",
    "release": "./build_release.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "dumi": "^2.4.21",
    "eslint": "^9.16.0",
    "globals": "^15.14.0",
    "prettier": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.0"
  },
  "packageManager": "pnpm@10.25.0+sha512.5e82639027af37cf832061bcc6d639c219634488e0f2baebe785028a793de7b525ffcd3f7ff574f5e9860654e098fe852ba8ac5dd5cefe1767d23a020a92f501"
}
